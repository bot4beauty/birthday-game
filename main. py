# ==============================
# CALLBACK ROUTER
# ==============================

async def handle_callback(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Unified callback handler - replaces multiple handlers"""
    if not await check_access(update):
        return
    
    query = update.callback_query
    data = query.data
    
    # Navigation callbacks
    if data in ["begin_journey", "continue_to_song", "continue_to_iwish", 
                "continue_to_reasons", "continue_to_finale", "launch_game", "return_from_game"]:
        handlers = {
            "begin_journey": handle_begin_journey,
            "continue_to_song": handle_continue_to_song,
            "continue_to_iwish": handle_continue_to_iwish,
            "continue_to_reasons": handle_continue_to_reasons,
            "continue_to_finale": handle_continue_to_finale,
            "launch_game": handle_launch_game,
            "return_from_game": handle_return_from_game,
        }
        await handlers[data](update, context)
    
    # I Wish callbacks
    elif data.startswith("iwish_"):
        if data == "iwish_reveal":
            await handle_iwish_reveal(update, context, query)
        elif data == "iwish_play":
            await play_iwish_song(update, context, query)
        elif data.startswith("iwish_guess_"):
            guess = data.replace("iwish_guess_", "")
            await handle_iwish_guess(update, context, query, guess)
    
    # Reasons callbacks
    elif data.startswith("reasons_begin"):
        await handle_reasons_begin(update, context)
    elif data.startswith("reason_view_"):
        await handle_reason_view(update, context)
    elif data.startswith("reason_complete_"):
        await handle_reason_complete(update, context)

