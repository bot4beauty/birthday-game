async def fallback_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if not await check_access(update):
        return
    
    state = context.user_data.get('conversation_state')
    
    if state == SONG_ANSWER:
        await handle_song_answer(update, context)
    elif state == QUIZ_ANSWER:
        await handle_quiz_answer(update, context)
    else:
        await animate_sparkle(update, context)
        await update.message.reply_text(
            "💕 I'm not expecting an answer right now.\n\n"
            "If you want to continue the journey, press the Continue button!"
        )

